{
  "name": "Apex Capital Management",
  "description": "Quantitative investment firm with equity trading, multi-asset allocation, and derivatives hedging",
  "version": "1.0.0",
  "environments": [
    {
      "name": "Apex Equities Desk",
      "id": "stock-trading",
      "description": "Directional equity trading using momentum, mean-reversion, and regime detection signals",
      "algorithm": "DQN (Double + Dueling)",
      "action_type": "discrete",
      "action_dim": 5,
      "observation_dim": 16,
      "tools": [
        {
          "name": "get_market_state",
          "description": "Fetch current price, volume, and 12 technical indicators (RSI, MACD, Bollinger, momentum, volatility, moving averages)",
          "parameters": {
            "lookback": {"type": "integer", "default": 30, "description": "Number of historical days to include"}
          },
          "returns": "observation vector (16-dim float array)"
        },
        {
          "name": "execute_trade",
          "description": "Execute a buy/sell/hold trade with automatic position sizing, transaction costs (10 bps), and slippage (5 bps)",
          "parameters": {
            "action": {"type": "integer", "enum": [0, 1, 2, 3, 4], "description": "0=strong_sell, 1=sell, 2=hold, 3=buy, 4=strong_buy"}
          },
          "returns": "reward (float), new observation, terminated flag"
        },
        {
          "name": "get_portfolio_status",
          "description": "Get current portfolio value, P&L, position size, drawdown from peak, Sharpe ratio, and trade count",
          "parameters": {},
          "returns": "dict with portfolio_value, total_return, sharpe_ratio, max_drawdown, trade_count, total_cost"
        }
      ],
      "scenarios": [
        {
          "id": "ST-001",
          "name": "Buy the Dip",
          "description": "RSI drops below 0.30 (oversold). Agent must identify the buying opportunity, enter a position, and exit when RSI normalizes.",
          "difficulty": "easy",
          "expected_steps": "3-5",
          "tools": ["get_market_state", "execute_trade", "get_portfolio_status"],
          "config": {"trigger": "rsi_oversold", "rsi_threshold": 0.30},
          "verifiers": [
            {"id": "STV-001", "name": "Return Threshold", "check": "total_return >= -0.25", "category": "outcome"},
            {"id": "STV-007", "name": "Action Sequence Valid", "check": "all actions in {0,1,2,3,4}", "category": "format"},
            {"id": "STV-010", "name": "Episode Completion", "check": "episode completed", "category": "completion"}
          ]
        },
        {
          "id": "ST-002",
          "name": "Trend Following",
          "description": "5-day MA crosses above 20-day MA (golden cross). Agent must enter long position and ride the trend until reversal signal.",
          "difficulty": "easy",
          "expected_steps": "4-6",
          "tools": ["get_market_state", "execute_trade", "get_portfolio_status"],
          "config": {"trigger": "ma_crossover", "fast_ma": 5, "slow_ma": 20},
          "verifiers": [
            {"id": "STV-001", "name": "Return Threshold", "check": "total_return >= -0.25", "category": "outcome"},
            {"id": "STV-002", "name": "Sharpe Ratio Check", "check": "sharpe_ratio >= -1.0", "category": "outcome"},
            {"id": "STV-010", "name": "Episode Completion", "check": "episode completed", "category": "completion"}
          ]
        },
        {
          "id": "ST-003",
          "name": "Mean Reversion Trade",
          "description": "Price deviates >2 standard deviations from 20-day mean (Bollinger breakout). Agent must fade the move and capture reversion.",
          "difficulty": "medium",
          "expected_steps": "3-5",
          "tools": ["get_market_state", "execute_trade", "get_portfolio_status"],
          "config": {"trigger": "bollinger_breakout", "std_threshold": 2.0},
          "verifiers": [
            {"id": "STV-001", "name": "Return Threshold", "check": "total_return >= -0.25", "category": "outcome"},
            {"id": "STV-003", "name": "Max Drawdown Limit", "check": "max_drawdown <= 0.40", "category": "risk"},
            {"id": "STV-010", "name": "Episode Completion", "check": "episode completed", "category": "completion"}
          ]
        },
        {
          "id": "ST-004",
          "name": "Momentum Scalping",
          "description": "Strong 10-day momentum (>3%). Agent must take quick directional trades and manage position sizing with transaction costs.",
          "difficulty": "medium",
          "expected_steps": "5-8",
          "tools": ["get_market_state", "execute_trade", "get_portfolio_status"],
          "config": {"trigger": "high_momentum", "momentum_threshold": 0.03},
          "verifiers": [
            {"id": "STV-001", "name": "Return Threshold", "check": "total_return >= -0.25", "category": "outcome"},
            {"id": "STV-005", "name": "Trade Frequency", "check": "trade_count <= 2 * episode_length", "category": "efficiency"},
            {"id": "STV-006", "name": "Transaction Cost Budget", "check": "total_cost <= 5000", "category": "cost"},
            {"id": "STV-010", "name": "Episode Completion", "check": "episode completed", "category": "completion"}
          ]
        },
        {
          "id": "ST-005",
          "name": "Volatile Market Navigation",
          "description": "Volatility spikes above 30% annualized. Agent must reduce exposure, avoid excessive trading, and preserve capital.",
          "difficulty": "medium",
          "expected_steps": "5-10",
          "tools": ["get_market_state", "execute_trade", "get_portfolio_status"],
          "config": {"trigger": "high_volatility", "volatility_threshold": 0.30},
          "verifiers": [
            {"id": "STV-003", "name": "Max Drawdown Limit", "check": "max_drawdown <= 0.40", "category": "risk"},
            {"id": "STV-005", "name": "Trade Frequency", "check": "trade_count <= 2 * episode_length", "category": "efficiency"},
            {"id": "STV-008", "name": "No Ruin", "check": "portfolio_value > 50000", "category": "survival"},
            {"id": "STV-010", "name": "Episode Completion", "check": "episode completed", "category": "completion"}
          ]
        },
        {
          "id": "ST-006",
          "name": "Drawdown Recovery",
          "description": "Portfolio has declined 15% from peak. Agent must recover without increasing risk. No aggressive positions allowed.",
          "difficulty": "hard",
          "expected_steps": "10-20",
          "tools": ["get_market_state", "execute_trade", "get_portfolio_status"],
          "config": {"trigger": "drawdown_recovery", "initial_drawdown": 0.15},
          "verifiers": [
            {"id": "STV-003", "name": "Max Drawdown Limit", "check": "max_drawdown <= 0.40", "category": "risk"},
            {"id": "STV-004", "name": "Position Limit", "check": "abs(position) <= 1.0", "category": "constraint"},
            {"id": "STV-008", "name": "No Ruin", "check": "portfolio_value > 50000", "category": "survival"},
            {"id": "STV-010", "name": "Episode Completion", "check": "episode completed", "category": "completion"}
          ]
        },
        {
          "id": "ST-007",
          "name": "Regime Change Adaptation",
          "description": "Market switches from bull to bear mid-episode. Agent must detect the shift and reverse from long to short/cash.",
          "difficulty": "hard",
          "expected_steps": "8-15",
          "tools": ["get_market_state", "execute_trade", "get_portfolio_status"],
          "config": {"trigger": "regime_switch", "switch_point": "mid_episode"},
          "verifiers": [
            {"id": "STV-001", "name": "Return Threshold", "check": "total_return >= -0.25", "category": "outcome"},
            {"id": "STV-002", "name": "Sharpe Ratio Check", "check": "sharpe_ratio >= -1.0", "category": "outcome"},
            {"id": "STV-003", "name": "Max Drawdown Limit", "check": "max_drawdown <= 0.40", "category": "risk"},
            {"id": "STV-010", "name": "Episode Completion", "check": "episode completed", "category": "completion"}
          ]
        },
        {
          "id": "ST-008",
          "name": "Cost-Aware Trading",
          "description": "High transaction cost environment (50 bps). Agent must minimize trade frequency while still capturing directional moves.",
          "difficulty": "hard",
          "expected_steps": "5-10",
          "tools": ["get_market_state", "execute_trade", "get_portfolio_status"],
          "config": {"transaction_cost": 0.005, "trigger": "high_cost_environment"},
          "verifiers": [
            {"id": "STV-001", "name": "Return Threshold", "check": "total_return >= -0.25", "category": "outcome"},
            {"id": "STV-005", "name": "Trade Frequency", "check": "trade_count <= episode_length", "category": "efficiency"},
            {"id": "STV-006", "name": "Transaction Cost Budget", "check": "total_cost <= 5000", "category": "cost"},
            {"id": "STV-010", "name": "Episode Completion", "check": "episode completed", "category": "completion"}
          ]
        },
        {
          "id": "ST-009",
          "name": "Full Episode Optimization",
          "description": "Complete trading episode from start to finish (~500 steps). Maximize Sharpe ratio over the full period.",
          "difficulty": "hard",
          "expected_steps": "400-500",
          "tools": ["get_market_state", "execute_trade", "get_portfolio_status"],
          "config": {"n_steps": 500, "reward_type": "sharpe"},
          "verifiers": [
            {"id": "STV-001", "name": "Return Threshold", "check": "total_return >= -0.25", "category": "outcome"},
            {"id": "STV-002", "name": "Sharpe Ratio Check", "check": "sharpe_ratio >= -1.0", "category": "outcome"},
            {"id": "STV-003", "name": "Max Drawdown Limit", "check": "max_drawdown <= 0.40", "category": "risk"},
            {"id": "STV-006", "name": "Transaction Cost Budget", "check": "total_cost <= 5000", "category": "cost"},
            {"id": "STV-008", "name": "No Ruin", "check": "portfolio_value > 50000", "category": "survival"},
            {"id": "STV-009", "name": "Reward Consistency", "check": "abs(mean_reward) < 100", "category": "sanity"},
            {"id": "STV-010", "name": "Episode Completion", "check": "episode completed", "category": "completion"}
          ]
        },
        {
          "id": "ST-010",
          "name": "Earnings Shock Response",
          "description": "Sudden 5% price gap (simulated). Agent must decide: hold through, cut losses, or add to position.",
          "difficulty": "expert",
          "expected_steps": "3-5",
          "tools": ["get_market_state", "execute_trade", "get_portfolio_status"],
          "config": {"trigger": "price_gap", "gap_size": 0.05},
          "verifiers": [
            {"id": "STV-001", "name": "Return Threshold", "check": "total_return >= -0.25", "category": "outcome"},
            {"id": "STV-003", "name": "Max Drawdown Limit", "check": "max_drawdown <= 0.40", "category": "risk"},
            {"id": "STV-008", "name": "No Ruin", "check": "portfolio_value > 50000", "category": "survival"},
            {"id": "STV-010", "name": "Episode Completion", "check": "episode completed", "category": "completion"}
          ]
        }
      ]
    },
    {
      "name": "Apex Multi-Asset Allocator",
      "id": "portfolio-allocation",
      "description": "Dynamic portfolio weight optimization across 5 correlated asset classes with cost-aware rebalancing",
      "algorithm": "PPO (Continuous)",
      "action_type": "continuous",
      "action_dim": 5,
      "observation_dim": 109,
      "tools": [
        {
          "name": "get_asset_returns",
          "description": "Fetch multi-asset return history with configurable lookback window for all 5 assets",
          "parameters": {
            "lookback": {"type": "integer", "default": 20, "description": "Number of historical days"}
          },
          "returns": "flattened return matrix (n_assets * lookback values)"
        },
        {
          "name": "rebalance_portfolio",
          "description": "Set target portfolio weights across 5 assets. Weights are normalized to sum to 1. Transaction costs applied to turnover.",
          "parameters": {
            "weights": {"type": "array", "items": "float", "length": 5, "description": "Target weights [w1, w2, w3, w4, w5] summing to 1.0"}
          },
          "returns": "reward (float), new observation, portfolio info"
        },
        {
          "name": "get_risk_metrics",
          "description": "Get portfolio Sharpe ratio, rolling volatility, maximum drawdown, current weights, and total return",
          "parameters": {},
          "returns": "dict with sharpe_ratio, volatility, max_drawdown, weights, total_return"
        }
      ],
      "scenarios": [
        {
          "id": "PA-001",
          "name": "Equal Weight Baseline",
          "description": "Maintain equal weights [0.20, 0.20, 0.20, 0.20, 0.20] across 5 assets. Baseline for comparison.",
          "difficulty": "easy",
          "expected_steps": "100-200",
          "tools": ["get_asset_returns", "rebalance_portfolio", "get_risk_metrics"],
          "config": {"strategy": "equal_weight", "n_assets": 5},
          "verifiers": [
            {"id": "PAV-001", "name": "Weights Sum to 1", "check": "abs(sum(weights) - 1.0) < 0.01", "category": "constraint"},
            {"id": "PAV-002", "name": "Non-Negative Weights", "check": "all(weights >= 0)", "category": "constraint"},
            {"id": "PAV-010", "name": "Episode Completion", "check": "status == completed", "category": "completion"}
          ]
        },
        {
          "id": "PA-002",
          "name": "Concentrated Bet",
          "description": "Identify the best-performing asset and allocate 80%+ to it. High risk, high reward.",
          "difficulty": "easy",
          "expected_steps": "50-100",
          "tools": ["get_asset_returns", "rebalance_portfolio", "get_risk_metrics"],
          "config": {"strategy": "concentrated", "max_single_weight": 0.80},
          "verifiers": [
            {"id": "PAV-001", "name": "Weights Sum to 1", "check": "abs(sum(weights) - 1.0) < 0.01", "category": "constraint"},
            {"id": "PAV-004", "name": "Portfolio Return", "check": "total_return >= -0.30", "category": "outcome"},
            {"id": "PAV-010", "name": "Episode Completion", "check": "status == completed", "category": "completion"}
          ]
        },
        {
          "id": "PA-003",
          "name": "Risk Parity Allocation",
          "description": "Allocate inversely proportional to each asset's volatility. Lower-vol assets get more weight.",
          "difficulty": "medium",
          "expected_steps": "100-200",
          "tools": ["get_asset_returns", "rebalance_portfolio", "get_risk_metrics"],
          "config": {"strategy": "risk_parity"},
          "verifiers": [
            {"id": "PAV-001", "name": "Weights Sum to 1", "check": "abs(sum(weights) - 1.0) < 0.01", "category": "constraint"},
            {"id": "PAV-005", "name": "Sharpe Ratio", "check": "sharpe_ratio >= -1.5", "category": "outcome"},
            {"id": "PAV-008", "name": "Diversification", "check": "herfindahl_index < 0.5", "category": "quality"},
            {"id": "PAV-010", "name": "Episode Completion", "check": "status == completed", "category": "completion"}
          ]
        },
        {
          "id": "PA-004",
          "name": "Correlation Regime Shift",
          "description": "Asset correlations change mid-episode (e.g., from 0.3 to 0.8). Agent must detect and diversify accordingly.",
          "difficulty": "medium",
          "expected_steps": "150-250",
          "tools": ["get_asset_returns", "rebalance_portfolio", "get_risk_metrics"],
          "config": {"trigger": "correlation_shift", "correlation_before": 0.3, "correlation_after": 0.8},
          "verifiers": [
            {"id": "PAV-001", "name": "Weights Sum to 1", "check": "abs(sum(weights) - 1.0) < 0.01", "category": "constraint"},
            {"id": "PAV-006", "name": "Max Drawdown", "check": "max_drawdown <= 0.50", "category": "risk"},
            {"id": "PAV-008", "name": "Diversification", "check": "herfindahl_index < 0.5", "category": "quality"},
            {"id": "PAV-010", "name": "Episode Completion", "check": "status == completed", "category": "completion"}
          ]
        },
        {
          "id": "PA-005",
          "name": "Low-Turnover Optimization",
          "description": "Maximize return while keeping monthly turnover below 20%. Transaction costs are elevated (20 bps).",
          "difficulty": "medium",
          "expected_steps": "100-200",
          "tools": ["get_asset_returns", "rebalance_portfolio", "get_risk_metrics"],
          "config": {"transaction_cost": 0.002, "max_turnover": 0.20},
          "verifiers": [
            {"id": "PAV-001", "name": "Weights Sum to 1", "check": "abs(sum(weights) - 1.0) < 0.01", "category": "constraint"},
            {"id": "PAV-007", "name": "Turnover Budget", "check": "cumulative_turnover <= 5.0", "category": "cost"},
            {"id": "PAV-009", "name": "Cost Efficiency", "check": "total_cost <= 30000", "category": "cost"},
            {"id": "PAV-010", "name": "Episode Completion", "check": "status == completed", "category": "completion"}
          ]
        },
        {
          "id": "PA-006",
          "name": "Tail Risk Hedging",
          "description": "One asset has fat-tailed returns (Student-t, df=3). Agent must limit exposure to the risky asset.",
          "difficulty": "hard",
          "expected_steps": "100-200",
          "tools": ["get_asset_returns", "rebalance_portfolio", "get_risk_metrics"],
          "config": {"fat_tail_asset": 0, "tail_df": 3},
          "verifiers": [
            {"id": "PAV-001", "name": "Weights Sum to 1", "check": "abs(sum(weights) - 1.0) < 0.01", "category": "constraint"},
            {"id": "PAV-003", "name": "Max Single Asset", "check": "max(weights) <= 0.80", "category": "risk"},
            {"id": "PAV-006", "name": "Max Drawdown", "check": "max_drawdown <= 0.50", "category": "risk"},
            {"id": "PAV-010", "name": "Episode Completion", "check": "status == completed", "category": "completion"}
          ]
        },
        {
          "id": "PA-007",
          "name": "Multi-Objective: Return + ESG",
          "description": "Maximize return while keeping allocation to green assets (assets 1,2) above 40%.",
          "difficulty": "hard",
          "expected_steps": "100-200",
          "tools": ["get_asset_returns", "rebalance_portfolio", "get_risk_metrics"],
          "config": {"green_assets": [0, 1], "min_green_allocation": 0.40},
          "verifiers": [
            {"id": "PAV-001", "name": "Weights Sum to 1", "check": "abs(sum(weights) - 1.0) < 0.01", "category": "constraint"},
            {"id": "PAV-004", "name": "Portfolio Return", "check": "total_return >= -0.30", "category": "outcome"},
            {"id": "PAV-008", "name": "Diversification", "check": "herfindahl_index < 0.5", "category": "quality"},
            {"id": "PAV-010", "name": "Episode Completion", "check": "status == completed", "category": "completion"}
          ]
        },
        {
          "id": "PA-008",
          "name": "Crisis Allocation",
          "description": "Bear market across all assets. Agent must find the least-bad allocation and minimize losses.",
          "difficulty": "hard",
          "expected_steps": "100-200",
          "tools": ["get_asset_returns", "rebalance_portfolio", "get_risk_metrics"],
          "config": {"regime": "bear", "all_assets_negative": true},
          "verifiers": [
            {"id": "PAV-001", "name": "Weights Sum to 1", "check": "abs(sum(weights) - 1.0) < 0.01", "category": "constraint"},
            {"id": "PAV-004", "name": "Portfolio Return", "check": "total_return >= -0.30", "category": "outcome"},
            {"id": "PAV-006", "name": "Max Drawdown", "check": "max_drawdown <= 0.50", "category": "risk"},
            {"id": "PAV-010", "name": "Episode Completion", "check": "status == completed", "category": "completion"}
          ]
        },
        {
          "id": "PA-009",
          "name": "Dynamic Rebalancing",
          "description": "Full episode with monthly rebalancing. Agent adapts weights based on rolling 60-day metrics.",
          "difficulty": "expert",
          "expected_steps": "200-400",
          "tools": ["get_asset_returns", "rebalance_portfolio", "get_risk_metrics"],
          "config": {"rebalance_frequency": 21, "lookback": 60},
          "verifiers": [
            {"id": "PAV-001", "name": "Weights Sum to 1", "check": "abs(sum(weights) - 1.0) < 0.01", "category": "constraint"},
            {"id": "PAV-005", "name": "Sharpe Ratio", "check": "sharpe_ratio >= -1.5", "category": "outcome"},
            {"id": "PAV-007", "name": "Turnover Budget", "check": "cumulative_turnover <= 5.0", "category": "cost"},
            {"id": "PAV-010", "name": "Episode Completion", "check": "status == completed", "category": "completion"}
          ]
        },
        {
          "id": "PA-010",
          "name": "Markowitz vs RL",
          "description": "Benchmark scenario: compare RL weights against mean-variance optimal weights on same data.",
          "difficulty": "expert",
          "expected_steps": "200-400",
          "tools": ["get_asset_returns", "rebalance_portfolio", "get_risk_metrics"],
          "config": {"benchmark": "mean_variance", "risk_aversion": 1.0},
          "verifiers": [
            {"id": "PAV-001", "name": "Weights Sum to 1", "check": "abs(sum(weights) - 1.0) < 0.01", "category": "constraint"},
            {"id": "PAV-004", "name": "Portfolio Return", "check": "total_return >= -0.30", "category": "outcome"},
            {"id": "PAV-005", "name": "Sharpe Ratio", "check": "sharpe_ratio >= -1.5", "category": "outcome"},
            {"id": "PAV-006", "name": "Max Drawdown", "check": "max_drawdown <= 0.50", "category": "risk"},
            {"id": "PAV-010", "name": "Episode Completion", "check": "status == completed", "category": "completion"}
          ]
        }
      ]
    },
    {
      "name": "Apex Derivatives Hedging",
      "id": "options-pricing",
      "description": "Intelligent delta hedging for options book with stochastic volatility and transaction cost optimization",
      "algorithm": "PPO (Continuous)",
      "action_type": "continuous",
      "action_dim": 1,
      "observation_dim": 7,
      "tools": [
        {
          "name": "get_option_greeks",
          "description": "Fetch Black-Scholes delta, gamma, current moneyness (S/K), time to expiry, and implied volatility",
          "parameters": {},
          "returns": "dict with delta, gamma, moneyness, time_to_expiry, sigma"
        },
        {
          "name": "adjust_hedge",
          "description": "Set the hedge ratio for the options position. 0=no hedge, 1=full BS delta hedge. Transaction costs applied to changes.",
          "parameters": {
            "hedge_ratio": {"type": "float", "min": -0.5, "max": 1.5, "description": "Target hedge ratio"}
          },
          "returns": "reward (float), new observation, P&L info"
        },
        {
          "name": "get_pnl_status",
          "description": "Get current hedging P&L, P&L variance, hedge position size, and hedging error relative to BS delta",
          "parameters": {},
          "returns": "dict with pnl, pnl_variance, hedge_position, hedge_error, bs_delta"
        }
      ],
      "scenarios": [
        {
          "id": "OP-001",
          "name": "Full Delta Hedge",
          "description": "Maintain hedge ratio = Black-Scholes delta at every step. Baseline strategy.",
          "difficulty": "easy",
          "expected_steps": "20-30",
          "tools": ["get_option_greeks", "adjust_hedge", "get_pnl_status"],
          "config": {"strategy": "full_delta", "sigma": 0.20},
          "verifiers": [
            {"id": "OPV-001", "name": "Hedge Ratio Bounds", "check": "-0.5 <= ratio <= 1.5", "category": "constraint"},
            {"id": "OPV-003", "name": "Hedging Error", "check": "avg |hedge - delta| < 0.5", "category": "quality"},
            {"id": "OPV-010", "name": "Episode Completion", "check": "all steps executed", "category": "completion"}
          ]
        },
        {
          "id": "OP-002",
          "name": "Static Hedge",
          "description": "Set hedge ratio once at start and hold. No rebalancing. Compare P&L variance against dynamic hedging.",
          "difficulty": "easy",
          "expected_steps": "20-30",
          "tools": ["get_option_greeks", "adjust_hedge", "get_pnl_status"],
          "config": {"strategy": "static", "initial_hedge": 0.5},
          "verifiers": [
            {"id": "OPV-001", "name": "Hedge Ratio Bounds", "check": "-0.5 <= ratio <= 1.5", "category": "constraint"},
            {"id": "OPV-002", "name": "P&L Above Minimum", "check": "pnl >= -50000", "category": "outcome"},
            {"id": "OPV-010", "name": "Episode Completion", "check": "all steps executed", "category": "completion"}
          ]
        },
        {
          "id": "OP-003",
          "name": "Cost-Aware Hedging",
          "description": "Transaction cost = 50 bps. Agent must hedge less frequently to save costs while managing risk.",
          "difficulty": "medium",
          "expected_steps": "20-30",
          "tools": ["get_option_greeks", "adjust_hedge", "get_pnl_status"],
          "config": {"transaction_cost": 0.005, "sigma": 0.20},
          "verifiers": [
